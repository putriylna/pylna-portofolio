<script>
  const nav = document.getElementById('astro-nav');

  window.addEventListener('scroll', function() {
    const isAtBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 20;
    
    if (isAtBottom) {
      nav.classList.remove('translate-y-1/2');
      nav.classList.add('translate-y-[150%]');
    } else {
      nav.classList.remove('translate-y-[150%]');
      nav.classList.add('translate-y-1/2');
    }
  });
</script>