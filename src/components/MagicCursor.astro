<div class="cursor-wrapper" id="wrapper">
  <div id="fluid-cursor"></div>
</div>

<script>
  function initMagicCursor() {
    const cursorElement = document.getElementById('fluid-cursor');
    const wrapper = document.getElementById('wrapper');
    if (!(cursorElement instanceof HTMLElement) || !(wrapper instanceof HTMLElement)) return;
    const cursor = cursorElement;

    let mouse = { x: 0, y: 0 };
    let pos = { x: 0, y: 0 };
    let lastPos = { x: 0, y: 0 };
    let hue = 200;
    let timeoutId: number | undefined;
    let tick = 0;

    const speed = 0.08;
    const stretchLimit = 1.5;

    wrapper.style.opacity = '0';

    window.addEventListener('mousemove', (event) => {
      wrapper.style.opacity = '1';
      mouse.x = event.clientX;
      mouse.y = event.clientY;

      if (timeoutId !== undefined) {
        clearTimeout(timeoutId);
      }
      timeoutId = window.setTimeout(() => {
        wrapper.style.opacity = '0';
      }, 1200);
    });

    function animate() {
      tick += 1;
      pos.x += (mouse.x - pos.x) * speed;
      pos.y += (mouse.y - pos.y) * speed;

      const deltaX = pos.x - lastPos.x;
      const deltaY = pos.y - lastPos.y;
      const velocity = Math.sqrt(deltaX * deltaX + deltaY * deltaY);
      const stretch = Math.min(1 + velocity / 60, stretchLimit);
      const angle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);

      hue = (hue + 0.5) % 360;

      const r1 = 50 + Math.sin(tick * 0.04) * 20;
      const r2 = 50 + Math.cos(tick * 0.02) * 20;
      cursor.style.borderRadius = `${r1}% ${100 - r1}% ${r2}% ${100 - r2}% / ${r2}% ${r1}% ${100 - r1}% ${100 - r2}%`;

      cursor.style.transform = `translate3d(${pos.x}px, ${pos.y}px, 0) rotate(${angle}deg) scale(${stretch}, ${1 / Math.max(stretch * 0.5, 1)})`;
      cursor.style.background = `radial-gradient(circle at 30% 30%, hsl(${hue}, 60%, 80%) 10%, transparent 80%)`;

      lastPos.x = pos.x;
      lastPos.y = pos.y;
      requestAnimationFrame(animate);
    }

    animate();
  }

  if (document.readyState === 'loading') {
    window.addEventListener('DOMContentLoaded', initMagicCursor);
  } else {
    initMagicCursor();
  }
</script>

<style>
  :global(html), :global(body) {
    margin: 0;
  }

  .cursor-wrapper {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 999998;
    filter: blur(45px) contrast(1.8);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  #fluid-cursor {
    position: absolute;
    top: -75px;
    left: -75px;
    width: 150px;
    height: 150px;
    will-change: transform, border-radius;
    mix-blend-mode: screen;
    opacity: 0.6;
  }
</style>